# Copy this file to .env and fill in real values. Never commit .env.

# --- Trading mode -----------------------------------------------------------
# "paper" (default, safe) or "live". Live ALSO requires LIVE_TRADING_CONFIRM
# below to be set to the exact phrase — see brokebyte/config.py.
TRADING_MODE=paper

# --- Alpaca: paper keys (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=

# --- Alpaca: live keys -------------------------------------------------------
# Separate key set from paper. Only read when TRADING_MODE=live.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# Required (in addition to TRADING_MODE=live) to allow live mode to start.
# Leave unset/commented out for normal (paper) operation.
# LIVE_TRADING_CONFIRM=I_UNDERSTAND_LIVE_TRADING_RISK

# --- LLM ----------------------------------------------------------------
# Required from Phase 3 onward (LLM reasoning layer). If unset, the bot
# fails safe to an always-HOLD provider rather than trading blind.
ANTHROPIC_API_KEY=

# Optional: override the two-tier models (Module 2). Defaults match the
# current Claude lineup; swap via env var only, no code changes.
# LLM_HAIKU_MODEL=claude-haiku-4-5-20251001
# LLM_SONNET_MODEL=claude-sonnet-4-6

# --- Misc ---------------------------------------------------------------
LOG_DIR=logs

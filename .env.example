# Copy this file to .env and fill in real values. Never commit .env.

# --- Trading mode -----------------------------------------------------------
# "paper" (default, safe) or "live". Live ALSO requires LIVE_TRADING_CONFIRM
# below to be set to the exact phrase — see brokebyte/config.py.
TRADING_MODE=paper

# --- Alpaca: paper keys (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_SECRET_KEY=

# --- Alpaca: live keys -------------------------------------------------------
# Separate key set from paper. Only read when TRADING_MODE=live.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_SECRET_KEY=

# Required (in addition to TRADING_MODE=live) to allow live mode to start.
# Leave unset/commented out for normal (paper) operation.
# LIVE_TRADING_CONFIRM=I_UNDERSTAND_LIVE_TRADING_RISK

# --- LLM ----------------------------------------------------------------
# Required from Phase 3 onward (LLM reasoning layer). If unset, the bot
# fails safe to an always-HOLD provider rather than trading blind.
ANTHROPIC_API_KEY=

# Optional: override the two-tier models (Module 2). Defaults match the
# current Claude lineup; swap via env var only, no code changes.
# LLM_HAIKU_MODEL=claude-haiku-4-5-20251001
# LLM_SONNET_MODEL=claude-sonnet-4-6

# --- Risk limits (optional overrides) -----------------------------------
# Minimum LLM confidence (0.0-1.0) required before the gate will consider
# entering a position. Verdicts below this floor are held regardless of
# other checks. Default: 0.60.
# RISK_MIN_CONFIDENCE=0.60

# --- Misc ---------------------------------------------------------------
LOG_DIR=logs

# How often (seconds) the position-reconciliation loop runs. Default: 300.
# RECONCILE_INTERVAL_SECONDS=300

# How long (seconds) the cached portfolio state is reused before a fresh
# Alpaca account/positions fetch is triggered. Default: 30.
# PORTFOLIO_CACHE_SECONDS=30

# --- Health report webhook (used by health_report.py / brokebyte-health.timer) ---
# Choose one delivery channel.
# HEALTH_WEBHOOK_KIND=discord            # slack | discord | telegram
# HEALTH_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy   # for slack/discord
# For telegram instead of the URL above:
# HEALTH_WEBHOOK_KIND=telegram
# HEALTH_TELEGRAM_TOKEN=123456:ABC...
# HEALTH_TELEGRAM_CHAT_ID=987654321
